    {
      "parameters": {
        "toolDescription": "=Call this tool to get the appointment availability for a particular period on the calendar. The tool may refer to availability as \"Free\" or \"Busy\".\n\nCRITICAL: You must format {timeMin} and {timeMax} strictly as ISO 8601 / RFC 3339 strings using the 24-hour clock and the +01:00 timezone offset for Lagos/Nigeria. Do not pass conversational times or \"WAT\" text.\n\nFor example, to check availability for September 20, 2026, between 9:00 AM and 5:00 PM WAT, you must set:\n- {timeMin} to \"2026-09-20T09:00:00+01:00\"\n- {timeMax} to \"2026-09-20T17:00:00+01:00\"\n\nIf the tool returns an empty response, it means that something went wrong. It does not mean that there is no availability.",
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/freeBusy",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"timeMin\": \"{{ $fromAI('timeMin') }}\",\n  \"timeMax\": \"{{ $fromAI('timeMax') }}\",\n  \"timeZone\": \"Africa/Lagos\",\n  \"groupExpansionMax\": 20,\n  \"calendarExpansionMax\": 10,\n  \"items\": [\n    {\n      \"id\": \"emmanueldevautomation@gmail.com\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [
        448,
        224
      ],
      "id": "08a1cb61-ce58-4442-8424-2be8c683c90d",
      "name": "Get calendar availability",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "aEJVzidMGNktltc7",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "toolDescription": "Call this tool to book an appointment in the calendar",
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/calendars/primary/events",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "sendUpdates",
              "value": "all"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"summary\": \"Appointment with {{ $fromAI('userName') }}\",\n  \"description\": \"Automated booking for {{ $fromAI('userName') }} ({{ $fromAI('userEmail') }}).\",\n  \"start\": {\n    \"dateTime\": \"{{ $fromAI('startTime') }}\",\n    \"timeZone\": \"Africa/Lagos\"\n  },\n  \"end\": {\n    \"dateTime\": \"{{ $fromAI('endTime') }}\",\n    \"timeZone\": \"Africa/Lagos\"\n  },\n  \"attendees\": [\n    {\n      \"email\": \"emmanueldevautomation@gmail.com\"\n    },\n    {\n      \"email\": \"{{ $fromAI('userEmail') }}\"\n    }\n  ]\n}",
        "options": {}
