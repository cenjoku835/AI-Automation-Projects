    {
      "parameters": {
        "promptType": "define",
        "text": "=Classify this email into one of these departments: Sales, Customer Service, HR, Finance, Operations, or Other. Reply with ONLY the department name.\n\nEmail Subject: {{ $json.subject }}\nEmail Body: {{ $json.body }}\nFrom: {{ $json.sender }}"
      },
      "id": "a6031a0c-b94c-44c9-862e-4e918420c3ae",
      "name": "Build AI Prompt",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        -1024,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst previousData = $('Needs AI Classification?').first().json;\n\nconst rawText = aiResponse.text || aiResponse.response || aiResponse.output || '';\nconst cleaned = rawText.trim().replace(/[^a-zA-Z ]/g, '');\n\nconst validDepts = ['Sales', 'Customer Service', 'HR', 'Finance', 'Operations', 'Other'];\nlet department = 'Other';\n\nfor (const dept of validDepts) {\n  if (cleaned.toLowerCase().includes(dept.toLowerCase())) {\n    department = dept;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...previousData,\n    department,\n    classificationMethod: 'ai',\n    aiRawResponse: rawText,\n    classifiedAt: new Date().toISOString()\n  }\n}];"
      },
