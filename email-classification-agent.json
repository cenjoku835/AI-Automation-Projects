      "id": "315d6454-bc27-48f0-b80d-91ed5b871921",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [
        -1696,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const emailData = $input.first().json;\n\nconst subject = (emailData.subject || emailData.payload?.headers?.find(h => h.name === 'Subject')?.value || '').toLowerCase();\nconst body = (emailData.snippet || emailData.body || emailData.textPlain || '').toLowerCase();\nconst sender = emailData.from || emailData.payload?.headers?.find(h => h.name === 'From')?.value || '';\nconst date = emailData.date || emailData.internalDate || new Date().toISOString();\nconst messageId = emailData.id || emailData.messageId || '';\n\nconst combined = subject + ' ' + body;\n\nconst keywords = {\n  Sales: [\n    'quote', 'pricing', 'proposal', 'purchase', 'buy', 'order', 'discount',\n    'demo', 'trial', 'subscription', 'upgrade', 'renewal', 'contract',\n    'deal', 'offer', 'revenue', 'prospect', 'lead', 'crm', 'opportunity'\n  ],\n  'Customer Service': [\n    'support', 'help', 'issue', 'problem', 'complaint', 'refund', 'return',\n    'broken', 'error', 'not working', 'ticket', 'request', 'feedback',\n    'dissatisfied', 'unhappy', 'cancel', 'cancellation', 'bug', 'fix'\n  ],\n  HR: [\n    'hire', 'hiring', 'job', 'application', 'resume', 'cv', 'interview',\n    'onboarding', 'payroll', 'leave', 'vacation', 'sick', 'benefits',\n    'employee', 'staff', 'recruitment', 'position', 'career', 'hr',\n    'human resources', 'performance review', 'training', 'policy'\n  ],\n  Finance: [\n    'invoice', 'payment', 'billing', 'receipt', 'tax', 'expense',\n    'reimbursement', 'budget', 'accounting', 'financial', 'wire',\n    'bank', 'transaction', 'audit', 'balance', 'statement', 'po number',\n    'purchase order', 'accounts payable', 'accounts receivable'\n  ],\n  Operations: [\n    'logistics', 'shipping', 'delivery', 'supply chain', 'vendor',\n    'supplier', 'warehouse', 'inventory', 'procurement', 'facility',\n    'maintenance', 'equipment', 'schedule', 'process', 'operations',\n    'infrastructure', 'dispatch', 'tracking', 'fulfillment'\n  ]\n};\n\nconst scores = {};\nfor (const [dept, words] of Object.entries(keywords)) {\n  scores[dept] = 0;\n  for (const word of words) {\n    if (combined.includes(word)) {\n      scores[dept] += 1;\n    }\n  }\n}\n\nconst maxScore = Math.max(...Object.values(scores));\nlet department = 'Other';\n\nif (maxScore > 0) {\n  department = Object.entries(scores).find(([, v]) => v === maxScore)[0];\n}\n\nreturn [{\n  json: {\n    messageId,\n    sender,\n    subject: emailData.subject || emailData.payload?.headers?.find(h => h.name === 'Subject')?.value || '',\n    body: emailData.snippet || emailData.textPlain || '',\n    date,\n    department,\n    scores,\n    classificationMethod: 'rule-based',\n    classifiedAt: new Date().toISOString()\n  }\n}];"
      },
